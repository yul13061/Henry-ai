import sounddevice as sd
from scipy.io.wavfile import write
from groq import Groq
import pyttsx3

API_KEY = ""

client = Groq(api_key=API_KEY)
engine = pyttsx3.init()

filename = "recording.wav"
seconds = 10
samplerate = 16000

while True:
    print("Speak now... you have about 10 seconds (say 'stop' to quit)")

    recording = sd.rec(int(seconds * samplerate), samplerate=samplerate, channels=1)
    sd.wait()

    write(filename, samplerate, recording)

    print("Transcribing...")

    with open(filename, "rb") as audio_file:
        transcription = client.audio.transcriptions.create(
            file=audio_file,
            model="whisper-large-v3"
        )

    print("You said:")
    print(transcription.text)

    if "stop" in transcription.text.lower():
        print("Stopping Henry.")
        engine.say("Okay, stopping now.")
        engine.runAndWait()
        break

    chat = client.chat.completions.create(
        model="llama-3.1-8b-instant",
        messages=[
            {"role": "user", "content": transcription.text}
        ]
    )

    reply = chat.choices[0].message.content

    print("trese says:")
    print(reply)

    engine.say(reply)
    engine.runAndWait()
